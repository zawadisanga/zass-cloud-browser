{
  "name": "zass-enterprise-ai",
  "version": "3.1.0",
  "description": "ZASS AI Enterprise - World's Most Advanced Browser Isolation Platform with AI Chatbot, Automatic Payment, and Enterprise Features",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install:browser": "npx playwright install chromium",
    "setup": "npm install && npm run install:browser",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate.js",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "test:api": "node scripts/test-api.js",
    "build": "npm run install:browser",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "backup:db": "cp database/zass_enterprise.sqlite database/backup_$(date +%Y%m%d_%H%M%S).sqlite"
  },
  "dependencies": {
    "express": "^4.18.2",
    "playwright": "^1.40.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "sqlite3": "^5.1.6",
    "sqlite": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "axios": "^1.6.2",
    "node-fetch": "^3.3.2",
    "winston": "^3.11.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "xss": "^1.0.14",
    "rate-limit-memcached": "^1.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "browser-isolation",
    "screenshot-api",
    "pdf-api",
    "anti-fingerprinting",
    "enterprise-security",
    "ai-chatbot",
    "automatic-payment",
    "nmb-bank",
    "cloud-browser",
    "ai-assistant",
    "zero-logs",
    "gdpr-compliant"
  ],
  "author": "ZASS Enterprise",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zawadisanga/zass-enterprise"
  },
  "bugs": {
    "url": "https://github.com/zawadisanga/zass-enterprise/issues"
  },
  "homepage": "https://zass.website",
  "funding": {
    "type": "bank",
    "url": "https://zass.website/payment"
  }
}
