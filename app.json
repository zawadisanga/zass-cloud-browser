{
  "name": "ZASS Cloud Browser Enterprise",
  "description": "World's Best Cloud Browser Hosting Platform",
  "repository": "https://github.com/zass/cloud-browser",
  "logo": "https://zass.website/logo.png",
  "keywords": ["browser", "automation", "playwright", "screenshot", "pdf", "api"],
  "env": {
    "MAX_WORKERS": {
      "description": "Number of browser workers",
      "value": "5",
      "required": false
    },
    "NODE_ENV": {
      "description": "Environment",
      "value": "production",
      "required": false
    }
  },
  "addons": [
    "heroku-redis:mini"
  ],
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
